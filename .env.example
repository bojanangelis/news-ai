# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=newsplus
POSTGRES_PASSWORD=newsplus_secret
POSTGRES_DB=newsplus_db
DATABASE_URL="postgresql://newsplus:newsplus_secret@localhost:5432/newsplus_db"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL="redis://:redis_secret@localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.key 2048
# Then: openssl rsa -in private.key -pubout -out public.key
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_TTL=900         # 15 minutes in seconds
JWT_REFRESH_TOKEN_TTL=604800     # 7 days in seconds

# ─── S3 / MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio_admin
S3_SECRET_ACCESS_KEY=minio_secret
S3_BUCKET_NAME=newsplus-media
S3_PUBLIC_URL=http://localhost:9000/newsplus-media

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── API keys (Next.js apps) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# ─── Stripe (Phase 2) ────────────────────────────────────────────────────────
