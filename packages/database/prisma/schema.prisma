// ─── Prisma Schema — NewsPlus ──────────────────────────────────────────────────
// Single source of truth for all database models.
// Run: pnpm --filter @repo/database db:generate

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  EDITOR
  WRITER
  ANALYST
  READER
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ArticleSectionType {
  PARAGRAPH
  HEADING
  QUOTE
  IMAGE
  EMBED
  CODE
  DIVIDER
  LIST
}

enum MediaAssetType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum HomepageSectionType {
  HERO
  FEATURED_GRID
  CATEGORY_ROW
  TRENDING
  EDITORS_PICK
}

enum NotificationType {
  BREAKING_NEWS
  NEW_ARTICLE_FROM_FOLLOWED_TOPIC
  NEW_ARTICLE_FROM_FOLLOWED_AUTHOR
  SYSTEM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum ScrapingSourceStatus {
  PENDING
  ACTIVE
  ERROR
  PAUSED
}

enum ScrapingLogStatus {
  SUCCESS
  PARTIAL
  ERROR
}

enum StoryStatus {
  ACTIVE
  MERGED
  ARCHIVED
}

enum ArticleRole {
  CANONICAL
  SUPPORTING
  RELATED
}

enum MatchMethod {
  EXACT_URL
  TITLE_FINGERPRINT
  ENTITY_OVERLAP
  MANUAL
}

enum EntityType {
  PERSON
  ORGANIZATION
  LOCATION
  EVENT
}

enum DedupeOutcome {
  JOINED_EXISTING
  CREATED_NEW
  EXACT_DUPLICATE_SKIPPED
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  bio          String?
  role         UserRole @default(READER)
  isActive     Boolean  @default(true)
  emailVerifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  authorProfile       Author?
  bookmarks           Bookmark[]
  topicFollows        TopicFollow[]
  articleViews        ArticleView[]
  notifications       Notification[]
  premiumSubscription PremiumSubscription?
  refreshTokens       RefreshToken[]
  auditLogs           AdminAuditLog[]
  scrapingSources     ScrapingSource[]

  @@index([email])
  @@index([role])
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  revokedAt   DateTime?
  userAgent   String?
  ipAddress   String?

  @@index([userId])
  @@index([tokenHash])
}

// ─── Author ───────────────────────────────────────────────────────────────────

model Author {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String    @unique
  displayName String
  bio         String?
  avatarUrl   String?
  twitterUrl  String?
  linkedInUrl String?
  websiteUrl  String?
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles    Article[]

  @@index([slug])
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?   // hex color for UI accents
  iconUrl     String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles         Article[]
  homepageSections HomepageSection[]
  scrapingSources  ScrapingSource[]
  stories          Story[]

  @@index([slug])
}

// ─── Topic ────────────────────────────────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articleTopics ArticleTopic[]
  topicFollows  TopicFollow[]

  @@index([slug])
}

// ─── Tag ──────────────────────────────────────────────────────────────────────

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())

  articleTags ArticleTag[]

  @@index([slug])
}

// ─── Article ──────────────────────────────────────────────────────────────────

model Article {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  excerpt          String
  status           ArticleStatus @default(DRAFT)
  isPremium        Boolean       @default(false)
  isBreaking       Boolean       @default(false)
  readTimeMinutes  Int           @default(0)
  viewCount        Int           @default(0)
  bookmarkCount    Int           @default(0)
  popularityScore  Float         @default(0) // for trending (updated by background job)

  // Foreign keys
  authorId         String
  author           Author        @relation(fields: [authorId], references: [id])
  categoryId       String
  category         Category      @relation(fields: [categoryId], references: [id])
  coverImageId     String?
  coverImage       MediaAsset?   @relation("ArticleCover", fields: [coverImageId], references: [id])

  // Scraping origin (used for deduplication of scraped articles)
  sourceUrl        String?
  // Cover image URL scraped from RSS feed (og:image / media:thumbnail / enclosure)
  ogImageUrl       String?
  // Normalized title fingerprint for story clustering (word-bag, sorted, pipe-delimited)
  titleFingerprint String?

  // Timestamps
  publishedAt      DateTime?
  scheduledAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Full-text search vector (populated by trigger)
  searchVector     Unsupported("tsvector")?

  // Relations
  sections         ArticleSection[]
  articleTopics    ArticleTopic[]
  articleTags      ArticleTag[]
  bookmarks        Bookmark[]
  articleViews     ArticleView[]
  homepageItems    HomepageSectionItem[]
  storyArticles    StoryArticle[]
  articleEntities  ArticleEntity[]
  aiSummary        ArticleSummary?

  @@index([slug])
  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([authorId, status])
  @@index([isPremium, status])
  @@index([popularityScore(sort: Desc)])
  // Full-text index handled via raw migration
}

// ─── ArticleSection (rich content blocks) ────────────────────────────────────

model ArticleSection {
  id            String             @id @default(cuid())
  articleId     String
  article       Article            @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type          ArticleSectionType
  order         Int
  content       String?            // text content
  level         Int?               // for HEADING (1-6)
  url           String?            // for IMAGE / EMBED
  caption       String?            // for IMAGE
  attribution   String?            // for QUOTE
  language      String?            // for CODE
  mediaAssetId  String?
  mediaAsset    MediaAsset?        @relation(fields: [mediaAssetId], references: [id])
  metadata      Json?              // extensible for future block types

  @@index([articleId, order])
}

// ─── Join tables ──────────────────────────────────────────────────────────────

model ArticleTopic {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  topicId   String
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([articleId, topicId])
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// ─── Bookmark ─────────────────────────────────────────────────────────────────

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── TopicFollow ──────────────────────────────────────────────────────────────

model TopicFollow {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId    String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  followedAt DateTime @default(now())

  @@id([userId, topicId])
  @@index([userId])
}

// ─── ArticleView (analytics events) ──────────────────────────────────────────

model ArticleView {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId   String?  // anonymous tracking
  ipHash      String?  // hashed for privacy
  userAgent   String?
  referrer    String?
  readPercent Int?     // 0-100, how far they read
  timeOnPage  Int?     // seconds
  viewedAt    DateTime @default(now())

  @@index([articleId, viewedAt(sort: Desc)])
  @@index([userId])
  @@index([viewedAt(sort: Desc)])
}

// ─── MediaAsset ───────────────────────────────────────────────────────────────

model MediaAsset {
  id           String         @id @default(cuid())
  url          String
  thumbnailUrl String?
  altText      String?
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  type         MediaAssetType @default(IMAGE)
  s3Key        String         @unique
  uploadedById String?
  createdAt    DateTime       @default(now())

  articleCovers  Article[]        @relation("ArticleCover")
  articleSections ArticleSection[]

  @@index([type, createdAt(sort: Desc)])
}

// ─── PremiumSubscription ──────────────────────────────────────────────────────

model PremiumSubscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status               SubscriptionStatus @default(TRIALING)
  planType             String             @default("monthly") // "monthly" | "yearly"
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
  @@index([trialEndsAt])
}

// ─── ArticleSummary (AI-generated, stored per article) ───────────────────────

model ArticleSummary {
  id          String   @id @default(cuid())
  articleId   String   @unique
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  bullets     String[] // 5 key points in Macedonian
  sources     String[] // names of outlets mentioned in the article
  audioUrl    String?  // S3/MinIO URL for pre-generated TTS audio
  aiModel     String   @default("claude-haiku-4-5")
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articleId])
}

// ─── DailyBriefing (one per day, generated by cron) ──────────────────────────

model DailyBriefing {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  articleIds  String[] // ordered list of top article IDs for the day
  generatedAt DateTime @default(now())

  @@index([date(sort: Desc)])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?            // articleId, topicId, etc.
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
}

// ─── HomepageSection ──────────────────────────────────────────────────────────

model HomepageSection {
  id           String              @id @default(cuid())
  type         HomepageSectionType
  title        String?
  order        Int
  isActive     Boolean             @default(true)
  categoryId   String?
  category     Category?           @relation(fields: [categoryId], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  items        HomepageSectionItem[]

  @@index([order, isActive])
}

model HomepageSectionItem {
  id                String          @id @default(cuid())
  homepageSectionId String
  homepageSection   HomepageSection @relation(fields: [homepageSectionId], references: [id], onDelete: Cascade)
  articleId         String
  article           Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  order             Int

  @@unique([homepageSectionId, articleId])
  @@index([homepageSectionId, order])
}

// ─── ScrapingSource ───────────────────────────────────────────────────────────

model ScrapingSource {
  id                    String               @id @default(cuid())
  name                  String
  url                   String               @unique
  isActive              Boolean              @default(true)
  scrapeIntervalMinutes Int                  @default(60)
  maxPagesPerRun        Int                  @default(1)
  maxArticlesPerRun     Int                  @default(50)
  lastScrapedAt         DateTime?
  lastSuccessAt         DateTime?
  status                ScrapingSourceStatus @default(PENDING)
  errorMessage          String?
  notes                 String?
  consecutiveErrors     Int                  @default(0)
  totalArticlesSaved    Int                  @default(0)
  healthScore           Int?
  defaultCategoryId     String?
  defaultCategory       Category?            @relation(fields: [defaultCategoryId], references: [id])
  createdById           String
  createdBy             User                 @relation(fields: [createdById], references: [id])
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  logs                  ScrapingLog[]

  @@index([isActive, status])
  @@index([createdById])
}

model ScrapingLog {
  id               String            @id @default(cuid())
  sourceId         String
  source           ScrapingSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status           ScrapingLogStatus
  articlesFound    Int               @default(0)
  articlesSaved    Int               @default(0)
  articlesSkipped  Int               @default(0)
  articlesFailed   Int               @default(0)
  pagesVisited     Int               @default(1)
  feedUrl          String?
  durationMs       Int               @default(0)
  errorMessage     String?
  details          String?
  structuredData   Json?
  createdAt        DateTime          @default(now())

  @@index([sourceId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

// ─── Story (canonical story cluster) ─────────────────────────────────────────

model Story {
  id               String      @id @default(cuid())
  title            String
  summary          String?
  imageUrl         String?
  categoryId       String?
  category         Category?   @relation(fields: [categoryId], references: [id])
  firstPublishedAt DateTime
  lastPublishedAt  DateTime
  sourceCount      Int         @default(1)
  articleCount     Int         @default(1)
  status           StoryStatus @default(ACTIVE)
  isDeveloping     Boolean     @default(false)
  clusterConfidence Float      @default(1.0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  storyArticles    StoryArticle[]

  @@index([lastPublishedAt])
  @@index([categoryId, status])
  @@index([status, lastPublishedAt(sort: Desc)])
  @@map("stories")
}

// ─── StoryArticle (join: story ↔ article) ────────────────────────────────────

model StoryArticle {
  id          String      @id @default(cuid())
  storyId     String
  story       Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  articleId   String
  article     Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  role        ArticleRole @default(SUPPORTING)
  rankScore   Float       @default(0.5)
  matchMethod MatchMethod
  matchScore  Float
  addedAt     DateTime    @default(now())

  @@unique([storyId, articleId])
  @@index([storyId, role])
  @@index([articleId])
  @@map("story_articles")
}

// ─── Entity ───────────────────────────────────────────────────────────────────

model Entity {
  id             String    @id @default(cuid())
  name           String
  normalizedName String
  type           EntityType

  articleEntities ArticleEntity[]

  @@unique([normalizedName, type])
  @@map("entities")
}

// ─── ArticleEntity (join: article ↔ entity) ──────────────────────────────────

model ArticleEntity {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  entityId  String
  entity    Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  salience  Float   @default(1.0)

  @@id([articleId, entityId])
  @@map("article_entities")
}

// ─── DedupeDecision (audit log) ───────────────────────────────────────────────

model DedupeDecision {
  id        String        @id @default(cuid())
  articleId String
  storyId   String?
  decision  DedupeOutcome
  method    MatchMethod
  score     Float
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([articleId])
  @@index([createdAt(sort: Desc)])
  @@map("dedupe_decisions")
}

// ─── Ads ──────────────────────────────────────────────────────────────────────

enum AdType {
  POPUP
  TOP_BANNER
  INLINE_FEED
  SIDEBAR
  STICKY_BOTTOM
  SPONSORED_CARD
  FULL_SCREEN_TAKEOVER
}

enum AdPlacement {
  POPUP
  TOP_BANNER
  SIDEBAR_RIGHT
  FEED_INLINE
  STICKY_BOTTOM
  ARTICLE_INLINE
  SPONSORED_CARD
  FULL_SCREEN_TAKEOVER
}

enum AdStatus {
  PENDING
  APPROVED
  REJECTED
  PAUSED
  EXPIRED
}

enum AdDeviceTarget {
  ALL
  DESKTOP
  MOBILE
}

enum AdEventType {
  IMPRESSION
  CLICK
}

model Advertiser {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ads         Ad[]
  campaigns   AdCampaign[]

  @@index([isActive])
}

model AdCampaign {
  id           String     @id @default(cuid())
  name         String
  advertiserId String
  advertiser   Advertiser @relation(fields: [advertiserId], references: [id])
  budget       Float?     // optional budget tracking (MKD or EUR)
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean    @default(true)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ads          Ad[]

  @@index([advertiserId, isActive])
}

model Ad {
  id           String      @id @default(cuid())
  title        String      // internal name for admin
  advertiserId String
  advertiser   Advertiser  @relation(fields: [advertiserId], references: [id])
  campaignId   String?
  campaign     AdCampaign? @relation(fields: [campaignId], references: [id])

  // Creative assets
  imageUrl     String?
  videoUrl     String?
  altText      String?     // accessibility / fallback text

  // Ad format & placement
  type         AdType
  placement    AdPlacement
  deviceTarget AdDeviceTarget @default(ALL)

  // Targeting (empty array = target all)
  categoryTargets String[]  // category slugs (e.g. ["sport", "politika"])
  pageTargets     String[]  // URL path prefixes (e.g. ["/", "/category/sport"])

  // Destination
  destinationUrl String
  trackingUrl    String?   // optional 3rd-party impression tracker URL
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?

  // Scheduling
  startDate   DateTime
  endDate     DateTime
  totalDays   Int?      // planned run duration (informational)

  // Popup-specific config (only used when type = POPUP)
  popupDelaySec       Int     @default(0)   // seconds to wait before showing
  popupHomepageOnly   Boolean @default(false)

  // Rotation / priority
  priority    Int @default(5)   // 1–10; higher = served more often
  weight      Int @default(100) // weight for weighted-random rotation

  // Impression / click limits
  maxImpressionsPerDay Int?
  maxTotalImpressions  Int?
  maxClicks            Int?

  // Status
  status          AdStatus @default(PENDING)
  isEnabled       Boolean  @default(true)
  rejectionReason String?

  // Denormalized counters (updated by service on each event)
  totalImpressions Int @default(0)
  totalClicks      Int @default(0)

  // House ad: shown as fallback when no paid ads exist for a placement
  isHouseAd   Boolean @default(false)

  // Shareable read-only report token (send to advertiser)
  reportToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyStats AdDailyStat[]
  events     AdEvent[]

  @@index([placement, status, isEnabled])
  @@index([startDate, endDate])
  @@index([advertiserId])
  @@index([status, updatedAt(sort: Desc)])
  @@index([isHouseAd, placement, isEnabled])
}

// ─── Ad daily stats (one row per ad per day for fast analytics) ───────────────

model AdDailyStat {
  id          String   @id @default(cuid())
  adId        String
  ad          Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)

  @@unique([adId, date])
  @@index([date(sort: Desc)])
}

// ─── Individual ad events (for detailed analytics / frequency capping) ────────

model AdEvent {
  id         String       @id @default(cuid())
  adId       String
  ad         Ad           @relation(fields: [adId], references: [id], onDelete: Cascade)
  type       AdEventType
  sessionId  String?
  ipHash     String?      // SHA-256 of IP for privacy-safe dedup
  userAgent  String?
  deviceType String?      // "desktop" | "mobile" | "tablet"
  referer    String?
  createdAt  DateTime     @default(now())

  @@index([adId, type, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ─── AdminAuditLog ────────────────────────────────────────────────────────────

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // e.g. "article.publish", "user.ban", "homepage.reorder"
  entityType String   // e.g. "Article", "User", "HomepageSection"
  entityId   String?
  before     Json?    // snapshot before change
  after      Json?    // snapshot after change
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
}
