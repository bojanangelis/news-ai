{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"],
      "@repo/types": ["../../packages/types/src/index.ts"],
      "@repo/ui/*": ["../../packages/ui/src/*.tsx"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}